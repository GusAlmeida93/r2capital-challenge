# Airflow image (built from local Dockerfile)
AIRFLOW_IMAGE_NAME=r2-pipeline:latest
AIRFLOW_UID=50000

# In-container paths (must match volume mounts in docker-compose.yml)
LANDING_PATH=/opt/airflow/data/landing
ARCHIVE_PATH=/opt/airflow/data/archive
DUCKDB_PATH=/opt/airflow/data/warehouse/duckdb.db
EXPORT_PATH=/opt/airflow/data/exports
LOG_PATH=/opt/airflow/logs

# DuckDB UI service
DUCKDB_UI_PORT=4213

# dbt
DBT_PROJECT_DIR=/opt/airflow/include/dbt
DBT_PROFILES_DIR=/opt/airflow/include/dbt
DBT_LOG_PATH=/opt/airflow/logs/dbt
DBT_TARGET_PATH=/opt/airflow/include/dbt/target

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=false
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
